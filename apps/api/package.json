{
  "name": "@nurturing/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/apps/api/src/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "tsx --test src/**/*.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "migrate:deploy": "prisma migrate deploy && node dist/apps/api/src/index.js"
  },
  "dependencies": {
    "@clerk/express": "^2.1.19",
    "@nurturing/core": "*",
    "@nurturing/schemas": "*",
    "@prisma/client": "6.14.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.3",
    "prisma": "6.14.0",
    "supertest": "^7.1.1",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2"
  }
}
