{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "../..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@nurturing/core": ["../../packages/core/src/index.ts"],
      "@nurturing/schemas": ["../../packages/schemas/src/index.ts"]
    }
  },
  "include": ["src", "../../packages/core/src", "../../packages/schemas/src"],
  "exclude": ["node_modules", "dist"]
}
